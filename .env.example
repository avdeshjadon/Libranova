# Example Environment Variables for Backend
# Rename or copy this file to .env and configure it as shown below.

# ==========================================
# 🚀 PRODUCTION DATABASE (Aiven Cloud)
# ==========================================
# Use this when you are connecting to your live database on Aiven.
# (Recommended so you can test live data while working locally)
DB_URL=jdbc:mysql://<your_aiven_host>:<port>/defaultdb?createDatabaseIfNotExist=true&useSSL=true
DB_USERNAME=avnadmin
DB_PASSWORD=<your_aiven_password>

# ==========================================
# 💻 LOCAL DATABASE (Localhost MySQL)
# ==========================================
# Uncomment these if you want to use a local MySQL server instead.
# Comment out the Production block above if you use this.
# DB_URL=jdbc:mysql://localhost:3306/ebook?createDatabaseIfNotExist=true&useSSL=false
# DB_USERNAME=root
# DB_PASSWORD=your_local_password
