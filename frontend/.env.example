# Example Environment Variables for Frontend
# Rename or copy this file to .env and configure it as shown below.

# ==========================================
# 🚀 PRODUCTION BACKEND (Render)
# ==========================================
# Active by default. This makes your local frontend fetch live data from the cloud.
VITE_API_BASE_URL=https://<your_render_url>.onrender.com

# ==========================================
# 💻 LOCAL BACKEND (Spring Boot localhost)
# ==========================================
# Uncomment this and comment out the Production URL if you are making changes 
# to the Java code and running `mvn spring-boot:run` locally.
# VITE_API_BASE_URL=http://localhost:8081

# ==========================================
# 🔥 FIREBASE CONFIGURATION
# ==========================================
# Add your Firebase credentials below
VITE_FIREBASE_API_KEY=<your_api_key>
VITE_FIREBASE_AUTH_DOMAIN=<your_auth_domain>
VITE_FIREBASE_PROJECT_ID=<your_project_id>
VITE_FIREBASE_STORAGE_BUCKET=<your_storage_bucket>
VITE_FIREBASE_MESSAGING_SENDER_ID=<your_sender_id>
VITE_FIREBASE_APP_ID=<your_app_id>
VITE_FIREBASE_MEASUREMENT_ID=<your_measurement_id>
